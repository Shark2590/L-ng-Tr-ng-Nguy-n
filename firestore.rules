rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} { allow read, write: if false; }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- USERS ---
    function isValidUser(data) {
      // Basic type validation for User
      return data.uid is string &&
             data.username is string &&
             data.balance is number;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || request.auth.token.admin == true);
      allow list: if isSignedIn(); // Allow listing users for e.g. leaderboard
      allow create: if isOwner(userId) && isValidUser(incoming());
      // Allow self-updates and friend list modifications by any signed-in user
      allow update: if isSignedIn() && (
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'friends', 'lastActive', 'matchesRemaining', 'lastResetDate', 'botWins', 'currentLevel'])) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['balance'])) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['friends']))
      );
    }
    
    // --- GAMES ---
    match /games/{gameId} {
      allow create: if isSignedIn() && incoming().player1 == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.player1 == request.auth.uid || resource.data.player2 == request.auth.uid);
      allow list: if isSignedIn(); // Assume client filters
      allow update: if isSignedIn() && (
        (existing().status == 'waiting' && existing().player2 == null && incoming().player2 == request.auth.uid) ||
        (existing().player1 == request.auth.uid || existing().player2 == request.auth.uid)
      );
      allow delete: if isSignedIn() && existing().player1 == request.auth.uid;
    }

    // --- INVITATIONS ---
    match /invitations/{invId} {
      allow create: if isSignedIn() && incoming().fromId == request.auth.uid;
      allow list: if isSignedIn(); 
      allow get: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow update: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow delete: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
    }
    
    // --- FRIEND REQUESTS ---
    match /friend_requests/{reqId} {
      allow create: if isSignedIn() && incoming().fromId == request.auth.uid;
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow update: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow delete: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
    }
  }
}
